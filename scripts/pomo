#!/bin/zsh
# Pomo API の薄い CLI ラッパ。ターミナル・Claude Code・スクリプトから使う。
# 例: pomo start / pomo memo "Go の学習" / pomo finish / pomo stats
set -uo pipefail
BASE="http://127.0.0.1:51766"

die_not_running() {
  echo "Pomo.app が起動していません（open build/Pomo.app で起動してください）" >&2
  exit 1
}

req() {
  curl -sf "$@" || die_not_running
  echo
}

cmd="${1:-status}"
case "$cmd" in
  status|stats|sessions)
    req "$BASE/$cmd" ;;
  start|pause|finish|reset)
    req -X POST "$BASE/$cmd" ;;
  skip)
    req -X POST "$BASE/break/skip" ;;
  extend)
    req -X POST "$BASE/break/extend" ;;
  memo)
    shift
    [ $# -eq 0 ] && { echo "usage: pomo memo <テキスト>" >&2; exit 1 }
    if command -v jq >/dev/null; then
      jq -n --arg t "$*" '{text: $t}' | req -X POST "$BASE/memo" -H 'Content-Type: application/json' -d @-
    else
      req -X POST "$BASE/memo" -H 'Content-Type: application/json' -d "{\"text\": \"$*\"}"
    fi ;;
  -h|--help|help|*)
    cat >&2 <<'USAGE'
usage: pomo <command>
  status          現在の状態（phase / 残り or 経過 / メモ / 今日の実績）
  start           作業を開始
  pause           一時停止 ⇄ 再開
  finish          作業を終える（フロー: 作業時間に応じた休憩が自動開始）
  memo <テキスト>  進行中の作業にメモを付ける
  skip            休憩をスキップ
  extend          休憩を5分延長
  reset           リセット
  stats           今日・今週の集計
  sessions        全履歴（JSONL）
USAGE
    [ "$cmd" = "-h" ] || [ "$cmd" = "--help" ] || [ "$cmd" = "help" ] || exit 1 ;;
esac
